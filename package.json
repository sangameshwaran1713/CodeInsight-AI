{
  "name": "codeinsight-ai",
  "version": "1.0.0",
  "description": "CodeInsight AI - Full-stack AI-powered code analysis platform",
  "private": true,
  "scripts": {
    "start": "node start.js",
    "start:ollama": "ollama serve",
    "start:ai": "cd ai-service && python -m uvicorn app.main:app --host 127.0.0.1 --port 8000",
    "start:server": "cd server && npm run dev",
    "start:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install && cd ../ai-service && pip install -r requirements.txt",
    "build": "cd client && npm run build",
    "test": "cd server && npm test"
  },
  "keywords": [
    "code-analysis",
    "ai",
    "openai",
    "mern",
    "react",
    "nodejs",
    "python",
    "fastapi"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
